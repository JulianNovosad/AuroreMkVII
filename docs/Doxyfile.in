# Doxygen configuration template for AuroreMkVII
# Variables in @VAR@ format are substituted by CMake's configure_file()

PROJECT_NAME           = "AuroreMkVII"
PROJECT_BRIEF          = "Real-time vision-based fire control system"
PROJECT_NUMBER         = @PROJECT_VERSION@
OUTPUT_DIRECTORY       = @CMAKE_CURRENT_BINARY_DIR@/docs
INPUT                  = @CMAKE_SOURCE_DIR@/include @CMAKE_SOURCE_DIR@/src
RECURSIVE              = YES
FILE_PATTERNS          = *.cpp *.hpp *.h
EXTRACT_ALL            = YES
GENERATE_HTML          = YES
GENERATE_LATEX         = NO
QUIET                  = YES
WARN_IF_UNDOCUMENTED   = NO
